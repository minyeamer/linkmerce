                                  AdList              scope="0.results", 5 fields, ignore
                                  AssetViewList       scope="0.results", 6 fields, ignore
    meta/api/ads                  AdObjects           scope="data", 19 fields, ignore
    sabangnet/admin/order         OrderList           scope="data.orderList", 29 fields, raise
                                  ProductList         scope="data.list", 7 fields, raise
                                  SkuList             scope="data", 8 fields, raise
    sabangnet/admin/product       ProductList         body→scope="data.list", raise
                                  OptionList          body→scope="data.optionList", raise
    searchad/api/keyword          KeywordList         scope="keywordList", 7 fields, raise
    searchad/manage/exposure      AdList              body→scope="adList", ignore
    searchad/gfa/adreport         Content             scope="content", 12 fields, ignore
    smartstore/api/bizdata        MarketingChannelList scope="rows", 10 fields, raise
    smartstore/api/order          OrderStatusList     body→scope="data.lastChangeStatuses", raise
    smartstore/api/product        ProductList         scope="contents", 20 fields, ignore
                                  OptionList          scope="originProduct.detailAttribute.optionInfo", ignore
